{
  "name": "lavitto/typo3-form-to-database",
  "description": "Extends the TYPO3 form with a database finisher, to save every form-result in the database.",
  "version": "4.2.2",
  "type": "typo3-cms-extension",
  "keywords": [
    "TYPO3",
    "extension",
    "form",
    "save form",
    "typo3 form",
    "form to database"
  ],
  "homepage": "https://www.lavitto.ch/typo3-ext-form-to-database",
  "authors": [
    {
      "name": "Philipp Mueller",
      "email": "philipp.mueller@lavitto.ch",
      "homepage": "https://www.lavitto.ch"
    }
  ],
  "license": "GPL-3.0-or-later",
  "repositories": [
    {
      "type": "composer",
      "url": "https://composer.typo3.org/"
    }
  ],
  "config": {
    "vendor-dir": ".Build/vendor",
    "bin-dir": ".Build/bin",
    "sort-packages": true,
    "allow-plugins": {
      "typo3/class-alias-loader": true,
      "typo3/cms-composer-installers": true
    }
  },
  "require": {
    "php": "^8.2 || ^8.3 || ^8.4",
    "ext-json": "*",
    "typo3/cms-backend": "^13.4",
    "typo3/cms-core": "^13.4",
    "typo3/cms-extbase": "^13.4",
    "typo3/cms-fluid": "^13.4",
    "typo3/cms-form": "^13.4",
    "typo3/cms-frontend": "^13.4"
  },
  "suggest": {
    "mpdf/mpdf": "Allows downloading form results as a PDF"
  },
  "autoload": {
    "psr-4": {
      "Lavitto\\FormToDatabase\\": "Classes"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Lavitto\\FormToDatabase\\Test\\": "Tests"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "form_to_database",
      "web-dir": ".Build/Web"
    }
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.64",
    "helhum/typo3-console": "^8.2",
    "helmich/typo3-typoscript-lint": "^3.2",
    "mpdf/mpdf": "^8.2",
    "nikic/php-parser": "^5.3",
    "saschaegerer/phpstan-typo3": "^1.10",
    "typo3/cms-install": "^13.4",
    "typo3/cms-tstemplate": "^13.4",
    "typo3/testing-framework": "^9.0"
  }
}
